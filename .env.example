# --- OpenAI & Hugging Face ---
OPENAI_MODEL_ID=gpt-4.1-mini
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_ACCESS_TOKEN=your_huggingface_token
HUGGINGFACE_USER_NAME=your_huggingface_username

# --- Comet ML & Opik (Experiment Tracking & Observability) ---
COMET_API_KEY=your_comet_api_key
COMET_PROJECT_NAME=llm-twin
OPIK_PROJECT_NAME=llm-twin-monitoring
OPIK_API_KEY=your_opik_api_key

# --- MongoDB (Data Warehouse) ---
# Full URI format: mongodb://user:password@host:port
DATABASE_HOST=mongodb://localhost:27017
DATABASE_NAME=twin

# --- Qdrant (Vector DB) ---
USE_QDRANT_CLOUD=false
QDRANT_DATABASE_HOST=localhost
QDRANT_DATABASE_PORT=6333
QDRANT_API_KEY=

# --- GitHub Crawler ---
GITHUB_TOKEN=your_github_token

# --- vLLM Inference Server ---
VLLM_HOST=localhost